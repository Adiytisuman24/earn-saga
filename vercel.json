{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://earn-saga.onrender.com/api/$1"
    },
    {
      "source": "/callback",
      "destination": "https://earn-saga.onrender.com/api/callback"
    }
  ]
}
